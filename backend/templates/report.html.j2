<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ report.title }}</title>
<style>
  :root {
    /* ── Brand ── */
    --accent: #1a56db;
    --accent-light: #e8eefb;

    /* ── Text hierarchy (warm grays, no blue cast) ── */
    --text-primary: #1c1c1e;
    --text-body: #3a3a3c;
    --text-secondary: #636366;
    --text-tertiary: #8e8e93;

    /* ── Surfaces ── */
    --bg: #ffffff;
    --bg-alt: #fafafa;
    --bg-tertiary: #f2f2f7;

    /* ── Borders ── */
    --border-light: #f0f0f0;
    --border: #e5e5ea;
    --border-medium: #d1d1d6;
    --rule: #c7c7cc;

    /* ── Semantic (muted) ── */
    --success: #34a853;
    --success-bg: #e6f4ea;
    --warning-bg: #fef7e0;
    --warning-text: #7c6a0a;
    --info-bg: #e8eefb;
    --info-text: #1a56db;
    --danger-bg: #fce8e6;
    --danger-text: #c5221f;

    /* ── Spacing (8px grid) ── */
    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 40px;
    --space-2xl: 64px;
    --space-3xl: 80px;

    /* ── Typography scale (1.25 Major Third) ── */
    --text-xs: 11px;
    --text-sm: 13px;
    --text-base: 15px;
    --text-md: 17px;
    --text-lg: 20px;
    --text-xl: 25px;
    --text-2xl: 31px;
    --text-3xl: 39px;

    /* ── Font stacks ── */
    --font-heading: "Segoe UI", system-ui, -apple-system, "Helvetica Neue", sans-serif;
    --font-body: "Segoe UI", system-ui, -apple-system, "Helvetica Neue", sans-serif;
    --font-mono: "Cascadia Code", Consolas, "SF Mono", Menlo, monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font-body);
    color: var(--text-body);
    background: var(--bg);
    line-height: 1.75;
    font-size: var(--text-base);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Header ── */
  .report-header {
    background: var(--bg);
    color: var(--text-primary);
    padding: 56px 0 40px;
    margin-bottom: var(--space-xl);
    border-top: 4px solid var(--accent);
    border-bottom: 1px solid var(--border);
  }
  .report-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 12px;
    color: var(--text-primary);
    max-width: 600px;
  }
  .meta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }
  .badge {
    display: inline-block;
    padding: 0;
    background: none;
    border-radius: 0;
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-secondary);
  }
  .badge + .badge::before {
    content: "\00b7";
    margin: 0 12px;
    color: var(--rule);
  }

  /* ── Sections ── */
  .section { margin-bottom: var(--space-3xl); }
  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin-bottom: var(--space-sm);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }
  .section:first-of-type .section-title {
    border-top: none;
    padding-top: 0;
  }
  .section-number {
    font-weight: 400;
    color: var(--text-tertiary);
    margin-right: 8px;
    font-feature-settings: "tnum";
  }
  .section-narrative {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--text-body);
    margin-bottom: var(--space-lg);
    max-width: 640px;
  }
  .section-narrative strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* ── Table of Contents ── */
  .toc {
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg) 0;
    background: none;
    border-radius: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .toc-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--text-tertiary);
    margin-bottom: var(--space-md);
  }
  .toc-list {
    list-style: decimal;
    padding-left: 20px;
    columns: 2;
    column-gap: 40px;
  }
  .toc-list li {
    padding: 4px 0;
    break-inside: avoid;
  }
  .toc-list a {
    color: var(--text-body);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 400;
  }
  .toc-list a:hover { color: var(--accent); }

  /* ── Stat cards ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .stat-card {
    background: none;
    border: none;
    border-radius: 0;
    padding: var(--space-md) 0;
    text-align: left;
    border-top: 2px solid var(--text-primary);
  }
  .stat-card .value {
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.1;
    font-feature-settings: "tnum";
    letter-spacing: -0.02em;
  }
  .stat-card .label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--space-sm);
    color: var(--text-tertiary);
    font-weight: 500;
  }

  /* ── Findings list ── */
  .findings-list {
    list-style: none;
    padding: 0;
    counter-reset: findings;
  }
  .findings-list li {
    padding: var(--space-md) 0;
    padding-left: 28px;
    margin-bottom: 0;
    background: none;
    border-left: none;
    border-radius: 0;
    border-bottom: 1px solid var(--border-light);
    font-size: var(--text-base);
    color: var(--text-body);
    line-height: 1.65;
    counter-increment: findings;
    position: relative;
  }
  .findings-list li::before {
    content: counter(findings);
    position: absolute;
    left: 0;
    top: var(--space-md);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-tertiary);
    font-feature-settings: "tnum";
  }
  .findings-list li:last-child { border-bottom: none; }

  /* ── Alerts ── */
  .alert-group-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: var(--space-lg) 0 var(--space-sm);
    color: var(--text-tertiary);
  }
  .alert {
    padding: 10px var(--space-md);
    border-radius: 0;
    margin-bottom: 4px;
    font-size: var(--text-sm);
    border-left: 3px solid transparent;
    line-height: 1.6;
  }
  .alert-warning { background: var(--warning-bg); color: var(--warning-text); border-left-color: #d4a017; }
  .alert-info    { background: var(--info-bg);    color: var(--info-text);    border-left-color: var(--accent); }
  .alert-danger  { background: var(--danger-bg);  color: var(--danger-text);  border-left-color: #c5221f; }

  /* ── Profile table ── */
  .profile-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    font-feature-settings: "tnum";
  }
  .profile-table th {
    background: none;
    color: var(--text-tertiary);
    padding: var(--space-sm) 12px;
    text-align: left;
    font-weight: 600;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 2px solid var(--text-primary);
  }
  .profile-table td {
    padding: var(--space-sm) 12px;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-body);
  }
  .profile-table tr:hover td { background: var(--bg-alt); }
  .type-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .type-numeric     { background: #eef2ff; color: #3b5998; }
  .type-categorical { background: #fdf0f5; color: #9b2c5e; }
  .type-datetime    { background: #ecfdf5; color: #166534; }
  .type-text        { background: #fffbeb; color: #854d0e; }
  .type-boolean     { background: #f3f0ff; color: #6d28d9; }

  /* ── Cleaning ── */
  .cleaning-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .shape-card {
    background: none;
    border: none;
    border-radius: 0;
    padding: var(--space-md) 0;
    text-align: left;
    border-top: 2px solid var(--text-primary);
  }
  .shape-card.after { border-color: var(--success); background: none; }
  .shape-card .shape-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    font-weight: 500;
  }
  .shape-card .shape-value {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--text-primary);
    margin-top: var(--space-xs);
    font-feature-settings: "tnum";
  }
  .step-list { list-style: none; padding: 0; }
  .step-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-light);
  }
  .step-number {
    flex-shrink: 0;
    width: auto;
    height: auto;
    background: none;
    color: var(--text-tertiary);
    border-radius: 0;
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    font-feature-settings: "tnum";
    min-width: 20px;
  }
  .step-content { flex: 1; }
  .step-name { font-weight: 600; color: var(--text-primary); text-transform: capitalize; }
  .step-desc { font-size: var(--text-sm); color: var(--text-secondary); }
  .step-affected { font-size: var(--text-xs); color: var(--text-secondary); font-weight: 600; margin-top: 2px; }

  /* ── Chart grid ── */
  .chart-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }
  .chart-card {
    border: none;
    border-radius: 0;
    overflow: hidden;
    background: none;
    box-shadow: none;
  }
  .chart-card img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--border-light);
  }
  .chart-info {
    padding: var(--space-sm) 0;
  }
  .chart-title {
    font-weight: 600;
    color: var(--text-primary);
    font-size: var(--text-sm);
    line-height: 1.4;
  }
  .chart-desc {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 2px;
    line-height: 1.5;
  }
  .chart-annotation {
    font-size: var(--text-sm);
    color: var(--text-body);
    line-height: 1.6;
    padding-top: var(--space-sm);
    margin-top: var(--space-sm);
    border-top: 1px solid var(--border-light);
  }
  .chart-full { grid-column: 1 / -1; }

  /* ── Footer ── */
  .report-footer {
    margin-top: var(--space-3xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--border);
    text-align: left;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }

  /* ── Print ── */
  @media print {
    :root {
      --text-primary: #000000;
      --text-body: #1a1a1a;
      --text-secondary: #444444;
      --text-tertiary: #666666;
    }

    body {
      font-size: 12px;
      line-height: 1.65;
      color: #1a1a1a;
    }

    .container {
      max-width: 100%;
      padding: 0;
    }

    .report-header {
      padding: 0 0 16px;
      margin-bottom: 24px;
      border-top: 3px solid #000;
      border-bottom: 1px solid #ccc;
    }

    .report-header h1 { font-size: 24px; }

    .toc {
      page-break-after: always;
    }

    .toc-list a { color: #1a1a1a; }

    .section {
      page-break-inside: avoid;
    }

    .section-title {
      page-break-after: avoid;
      font-size: 18px;
    }

    .chart-card {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .chart-card img { border: none; }

    .chart-grid { gap: 16px; }

    .stat-card { border-top: 1px solid #000; }

    .profile-table th { border-bottom: 1.5px solid #000; }

    .profile-table td {
      font-size: 10px;
      padding: 4px 8px;
    }

    .profile-table tr:hover td { background: none; }

    .alert { border-left-width: 2px; }

    .stat-card .value { color: #000; }
  }

  @media (max-width: 700px) {
    .chart-grid { grid-template-columns: 1fr; }
    .cleaning-grid { grid-template-columns: 1fr; }
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
    .toc-list { columns: 1; }
  }
</style>
</head>
<body>

<!-- ── Header ── -->
<header class="report-header">
  <div class="container">
    <h1>{{ report.title }}</h1>
    <div class="meta-badges">
      <span class="badge">{{ report.dataset_filename }}</span>
      <span class="badge">{{ "{:,}".format(report.profile.total_rows) }} rows</span>
      <span class="badge">{{ report.profile.total_columns }} columns</span>
      <span class="badge">{{ report.generated_at }}</span>
    </div>
  </div>
</header>

<div class="container">

  <!-- ── Table of Contents ── -->
  <nav class="toc">
    <div class="toc-label">Contents</div>
    <ol class="toc-list">
      <li><a href="#executive-summary">Executive Summary</a></li>
      <li><a href="#data-overview">Data Overview</a></li>
      {% if report.alerts %}<li><a href="#data-quality-alerts">Data Quality Alerts</a></li>{% endif %}
      {% for section in report.sections %}
      <li><a href="#{{ section.id }}">{{ section.title }}</a></li>
      {% endfor %}
      {% if report.statistical_report %}<li><a href="#stat-tests">Statistical Test Results</a></li>{% endif %}
      {% if report.cleaning_report %}<li><a href="#cleaning">Cleaning Impact</a></li>{% endif %}
      <li><a href="#appendix">Appendix: Column Profiles</a></li>
    </ol>
  </nav>

  <!-- ── 1. Executive Summary ── -->
  <div class="section" id="executive-summary">
    <h2 class="section-title"><span class="section-number">1</span>Executive Summary</h2>
    {% if report.executive_narrative %}
    <p class="section-narrative">{{ report.executive_narrative }}</p>
    {% endif %}

    <div class="stat-grid">
      <div class="stat-card">
        <div class="value">{{ "{:,}".format(report.profile.total_rows) }}</div>
        <div class="label">Total Rows</div>
      </div>
      <div class="stat-card">
        <div class="value">{{ report.profile.total_columns }}</div>
        <div class="label">Columns</div>
      </div>
      <div class="stat-card">
        <div class="value">{{ "{:,}".format(report.profile.duplicate_row_count) }}</div>
        <div class="label">Duplicates</div>
      </div>
      <div class="stat-card">
        <div class="value">{{ report.alerts | length }}</div>
        <div class="label">Quality Alerts</div>
      </div>
    </div>

    {% if report.key_findings %}
    <ul class="findings-list">
      {% for finding in report.key_findings %}
      <li>{{ finding }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>

  <!-- ── 2. Data Overview ── -->
  <div class="section" id="data-overview">
    <h2 class="section-title"><span class="section-number">2</span>Data Overview</h2>
    {% if report.data_overview_narrative %}
    <p class="section-narrative">{{ report.data_overview_narrative }}</p>
    {% endif %}

    <div class="stat-grid">
      {% set ns = namespace(numeric=0, categorical=0, datetime=0, text=0, boolean=0) %}
      {% for col in report.profile.columns %}
        {% if col.inferred_type | enum_val == 'numeric' %}{% set ns.numeric = ns.numeric + 1 %}
        {% elif col.inferred_type | enum_val == 'categorical' %}{% set ns.categorical = ns.categorical + 1 %}
        {% elif col.inferred_type | enum_val == 'datetime' %}{% set ns.datetime = ns.datetime + 1 %}
        {% elif col.inferred_type | enum_val == 'text' %}{% set ns.text = ns.text + 1 %}
        {% elif col.inferred_type | enum_val == 'boolean' %}{% set ns.boolean = ns.boolean + 1 %}
        {% endif %}
      {% endfor %}
      {% if ns.numeric %}<div class="stat-card"><div class="value">{{ ns.numeric }}</div><div class="label">Numeric</div></div>{% endif %}
      {% if ns.categorical %}<div class="stat-card"><div class="value">{{ ns.categorical }}</div><div class="label">Categorical</div></div>{% endif %}
      {% if ns.datetime %}<div class="stat-card"><div class="value">{{ ns.datetime }}</div><div class="label">Datetime</div></div>{% endif %}
      {% if ns.text %}<div class="stat-card"><div class="value">{{ ns.text }}</div><div class="label">Text</div></div>{% endif %}
      {% if ns.boolean %}<div class="stat-card"><div class="value">{{ ns.boolean }}</div><div class="label">Boolean</div></div>{% endif %}
    </div>
  </div>

  <!-- ── 3. Data Quality Alerts ── -->
  {% if report.alerts %}
  {% set ns_section = namespace(counter=3) %}
  <div class="section" id="data-quality-alerts">
    <h2 class="section-title"><span class="section-number">{{ ns_section.counter }}</span>Data Quality Alerts</h2>
    <p class="section-narrative">
      {{ report.alerts | length }} alert{{ 's' if report.alerts | length != 1 else '' }}
      detected across the dataset. Issues are grouped by severity below.
    </p>

    {% set warnings = report.alerts | selectattr('severity', 'equalto', 'warning') | list %}
    {% set infos = report.alerts | selectattr('severity', 'equalto', 'info') | list %}
    {% set dangers = report.alerts | selectattr('severity', 'equalto', 'danger') | list %}

    {% if dangers %}
    <div class="alert-group-title">Critical ({{ dangers | length }})</div>
    {% for alert in dangers %}
    <div class="alert alert-danger">{{ alert.message }}</div>
    {% endfor %}
    {% endif %}

    {% if warnings %}
    <div class="alert-group-title">Warnings ({{ warnings | length }})</div>
    {% for alert in warnings %}
    <div class="alert alert-warning">{{ alert.message }}</div>
    {% endfor %}
    {% endif %}

    {% if infos %}
    <div class="alert-group-title">Informational ({{ infos | length }})</div>
    {% for alert in infos %}
    <div class="alert alert-info">{{ alert.message }}</div>
    {% endfor %}
    {% endif %}
  </div>
  {% set ns_section = namespace(counter=4) %}
  {% else %}
  {% set ns_section = namespace(counter=3) %}
  {% endif %}

  <!-- ── 4+. Thematic Chart Sections ── -->
  {% for section in report.sections %}
  <div class="section" id="{{ section.id }}">
    <h2 class="section-title"><span class="section-number">{{ ns_section.counter + loop.index0 }}</span>{{ section.title }}</h2>
    {% if section.narrative %}
    <p class="section-narrative">
      {{ section.narrative.headline }}
      {% if section.narrative.body %} {{ section.narrative.body }}{% endif %}
    </p>
    {% endif %}

    <div class="chart-grid">
      {% for chart in section.charts %}
      <figure class="chart-card{% if chart.chart_type | enum_val in ['heatmap', 'missing_matrix', 'treemap', 'sunburst', 'sankey', 'parallel_coords', 'pca_biplot', 'cluster_scatter', 'anomaly_scatter'] %} chart-full{% endif %}">
        <img src="data:image/png;base64,{{ chart.image_base64 }}" alt="{{ chart.title }}">
        <figcaption class="chart-info">
          <div class="chart-title">{{ chart.title }}</div>
          <div class="chart-desc">{{ chart.description }}</div>
          {% if chart.annotation %}
          <div class="chart-annotation">{{ chart.annotation }}</div>
          {% endif %}
        </figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  <!-- ── Statistical Test Results ── -->
  {% if report.statistical_report and report.statistical_report.tests %}
  <div class="section" id="stat-tests">
    <h2 class="section-title">Statistical Test Results</h2>
    <p class="section-narrative">
      Hypothesis tests quantify the significance of observed patterns.
      Tests with p &lt; 0.05 indicate statistically significant results.
    </p>

    {% if report.statistical_report.clusters or report.statistical_report.anomalies or report.statistical_report.pca %}
    <div class="stat-grid" style="margin-bottom: 24px;">
      {% if report.statistical_report.clusters %}
      <div class="stat-card">
        <div class="value">{{ report.statistical_report.clusters.optimal_k }}</div>
        <div class="label">Clusters Found</div>
      </div>
      {% endif %}
      {% if report.statistical_report.anomalies %}
      <div class="stat-card">
        <div class="value">{{ report.statistical_report.anomalies.n_anomalies }}</div>
        <div class="label">Anomalies Detected</div>
      </div>
      {% endif %}
      {% if report.statistical_report.pca %}
      <div class="stat-card">
        <div class="value">{{ report.statistical_report.pca.n_components_95 }}</div>
        <div class="label">PCA Components (95%)</div>
      </div>
      {% endif %}
    </div>
    {% endif %}

    <table class="profile-table">
      <thead>
        <tr>
          <th>Test</th>
          <th>Column(s)</th>
          <th>Statistic</th>
          <th>p-value</th>
          <th>Interpretation</th>
        </tr>
      </thead>
      <tbody>
        {% for test in report.statistical_report.tests %}
        <tr>
          <td><strong>{{ test.test_name }}</strong></td>
          <td>{{ test.columns | join(", ") }}</td>
          <td style="font-feature-settings: 'tnum';">{{ "%.4f"|format(test.statistic) }}</td>
          <td style="font-feature-settings: 'tnum'; {% if test.p_value < 0.05 %}color: var(--accent); font-weight: 600;{% endif %}">
            {{ "%.6f"|format(test.p_value) }}
          </td>
          <td style="font-size: 12px;">{{ test.interpretation }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  <!-- ── Cleaning Impact ── -->
  {% if report.cleaning_report %}
  <div class="section" id="cleaning">
    <h2 class="section-title">Cleaning Impact</h2>
    <p class="section-narrative">
      The automated cleaning pipeline processed the dataset in
      {{ "{:,}".format(report.cleaning_report.duration_ms) }}ms,
      applying {{ report.cleaning_report.steps | length }} transformation steps.
    </p>

    <div class="cleaning-grid">
      <div class="shape-card">
        <div class="shape-label">Before</div>
        <div class="shape-value">
          {{ "{:,}".format(report.cleaning_report.original_shape[0]) }} rows &times;
          {{ report.cleaning_report.original_shape[1] }} cols
        </div>
      </div>
      <div class="shape-card after">
        <div class="shape-label">After</div>
        <div class="shape-value">
          {{ "{:,}".format(report.cleaning_report.cleaned_shape[0]) }} rows &times;
          {{ report.cleaning_report.cleaned_shape[1] }} cols
        </div>
      </div>
    </div>

    <ol class="step-list">
      {% for step in report.cleaning_report.steps %}
      <li class="step-item">
        <div class="step-number">{{ loop.index }}</div>
        <div class="step-content">
          <div class="step-name">{{ step.step | replace("_", " ") }}</div>
          <div class="step-desc">{{ step.description }}</div>
          {% if step.rows_affected > 0 %}
          <div class="step-affected">{{ "{:,}".format(step.rows_affected) }} rows affected</div>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  <!-- ── Appendix: Column Profiles ── -->
  <div class="section" id="appendix">
    <h2 class="section-title">Appendix: Column Profiles</h2>
    <p class="section-narrative">Detailed metadata for each column in the dataset.</p>

    <table class="profile-table">
      <thead>
        <tr>
          <th>Column</th>
          <th>Type</th>
          <th>Nulls</th>
          <th>Null %</th>
          <th>Unique</th>
          <th>Sample Values</th>
        </tr>
      </thead>
      <tbody>
        {% for col in report.profile.columns %}
        <tr>
          <td><strong>{{ col.name }}</strong></td>
          <td><span class="type-badge type-{{ col.inferred_type | enum_val }}">{{ col.inferred_type | enum_val }}</span></td>
          <td>{{ "{:,}".format(col.null_count) }}</td>
          <td>{{ "%.1f"|format(col.null_pct) }}%</td>
          <td>{{ "{:,}".format(col.unique_count) }}</td>
          <td style="font-size: 12px; color: var(--text-tertiary);">{{ col.sample_values[:3] | join(", ") }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</div>

<!-- ── Footer ── -->
<footer class="report-footer">
  <div class="container">
    Generated by <strong>Data Autopilot</strong> &mdash; Automated Data Analysis Platform
  </div>
</footer>

</body>
</html>
